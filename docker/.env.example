# Copy to docker/.env (git-ignored). tools/offline_sync.sh generates .env
# automatically with random passwords if it does not exist yet.
DB_ROOT_PASSWORD=change_me_root
DB_PASSWORD=change_me_songs
# Port published on the host. 80 gives clean URLs (http://songs.lan/);
# change if something else already listens on 80.
HTTP_PORT=80
# 1 = build with LibreOffice + Ghostscript (sermon pptx import works, big image);
# 0 = small fast build, pptx import reports "LibreOffice missing".
WITH_PPTX=1
